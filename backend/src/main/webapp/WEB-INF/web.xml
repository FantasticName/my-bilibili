<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>MyBilibili</display-name>

    <!-- ==================== 全局字符编码过滤器 ==================== -->
    <!-- 解决请求和响应的中文乱码问题 -->
    <filter>
        <filter-name>CharacterEncodingFilter</filter-name>
        <filter-class>io.github.fantasticname.mybilibili.filter.CharacterEncodingFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>CharacterEncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- ==================== TraceId过滤器 ==================== -->
    <!-- 第一个执行的过滤器：生成TraceId，绑定到当前线程和MDC -->
    <!-- 必须放在最前面，确保后续所有代码的日志都带TraceId -->
    <filter>
        <filter-name>TraceIdFilter</filter-name>
        <filter-class>io.github.fantasticname.mybilibili.filter.TraceIdFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>TraceIdFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- ==================== 全局异常处理过滤器 ==================== -->
    <!-- 第二个执行的过滤器：捕获所有未处理的异常，返回统一格式的错误响应 -->
    <!-- 放在TraceIdFilter之后，确保异常日志也能带上TraceId -->
    <filter>
        <filter-name>GlobalExceptionFilter</filter-name>
        <filter-class>io.github.fantasticname.mybilibili.filter.GlobalExceptionFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>GlobalExceptionFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- ==================== AuthFilter ==================== -->
    <!-- 负责在请求处理完成后（finally块）清理UserContext，避免ThreadLocal污染线程 -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>io.github.fantasticname.mybilibili.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/api/*</url-pattern>
    </filter-mapping>

    <!-- ==================== IoC容器初始化监听器 ==================== -->
    <!-- Web应用启动时初始化IoC容器，扫描包、创建Bean、注入依赖 -->
    <listener>
        <listener-class>io.github.fantasticname.mybilibili.listener.ContainerInitializerListener</listener-class>
    </listener>

    <!-- ==================== DispatcherServlet ==================== -->
    <!-- 核心分发器：拦截所有请求，根据URL和HTTP方法找到对应的Controller方法 -->
    <!-- 它是手写Spring MVC框架的核心，等价于Spring的DispatcherServlet -->
    <servlet>
        <servlet-name>dispatcher</servlet-name>
        <servlet-class>io.github.fantasticname.mybilibili.servlet.DispatcherServlet</servlet-class>
        <!-- 在Web应用启动时就初始化Servlet，而不是等到第一个请求到来 -->
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>dispatcher</servlet-name>
        <!-- 拦截所有请求，由DispatcherServlet统一分发 -->
        <url-pattern>/api/*</url-pattern>
    </servlet-mapping>

    <!-- ==================== 欢迎页 ==================== -->
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

</web-app>
