# ============================================================
# MyBilibili 环境变量配置文件模板
# 复制此文件为 env.properties 并填入真实值
# env.properties 已被 .gitignore 排除，不会被提交到版本库
#
# 优先级：环境变量 > env.properties 文件
# ============================================================

# 管理员注册邀请码
# 环境变量：ADMIN_INVITE_CODE
admin.invite.code=

# Redis连接配置
# 环境变量：REDIS_HOST
redis.host=localhost
# 环境变量：REDIS_PORT
redis.port=6379
# 环境变量：REDIS_PASSWORD
redis.password=
# 环境变量：REDIS_DATABASE
redis.database=0

# JWT签名密钥
# 环境变量：JWT_SECRET
jwt.secret=

# Token在Redis中的过期时间（秒），默认30分钟
# 环境变量：JWT_TOKEN_TTL
jwt.token.ttl=1800
